load METARULE-SURFACE2.maude
load ILP-CORE.maude

fmod TEST-ILP-CORE is
  protecting ILP-CORE .

  --- ----------------------------------------------------------
  --- Dummy concrete sorts để test interface
  --- ----------------------------------------------------------
  sort Animal .
  subsort Animal < Entity .
  ops cat dog bird : -> Animal [ctor] .

  ops likes hates : -> Pred [ctor] .

  ops likes hates : Entity Entity -> Atom [ctor] .

  --- ----------------------------------------------------------
  --- Test Arity constants
  --- ----------------------------------------------------------
  op testUnary   : -> Arity .
  eq testUnary   = unary .

  op testBinary  : -> Arity .
  eq testBinary  = binary .

  op testTernary : -> Arity .
  eq testTernary = ternary .

  --- ----------------------------------------------------------
  --- Test PredDecl
  --- ----------------------------------------------------------
  op testPredDecl1 : -> PredDecl .
  eq testPredDecl1 = predDecl(likes, binary) .

  op testPredDecl2 : -> PredDecl .
  eq testPredDecl2 = predDecl(hates, binary) .

  --- ----------------------------------------------------------
  --- Test PredDeclList
  --- ----------------------------------------------------------
  op testPREDS : -> PredDeclList .
  eq testPREDS =
    predDecl(likes, binary) ;
    predDecl(hates, binary) .

  --- ----------------------------------------------------------
  --- Test Atom
  --- ----------------------------------------------------------
  op testAtom1 : -> Atom .
  eq testAtom1 = likes(cat, dog) .

  op testAtom2 : -> Atom .
  eq testAtom2 = hates(dog, bird) .

  --- ----------------------------------------------------------
  --- Test AtomList
  --- ----------------------------------------------------------
  op testAtomList1 : -> AtomList .
  eq testAtomList1 =
    likes(cat, dog) ;
    hates(dog, bird) .

  op testAtomList2 : -> AtomList .
  eq testAtomList2 = nilAtom .

  --- ----------------------------------------------------------
  --- Test atom1 / atom2 / atom3 generic constructors
  --- ----------------------------------------------------------
  op testAtom2Generic : -> Atom .
  eq testAtom2Generic = atom2(likes, cat, dog) .

  op testAtom1Generic : -> Atom .
  eq testAtom1Generic = atom1(likes, cat) .

  --- ----------------------------------------------------------
  --- Test METARULES interface
  --- ----------------------------------------------------------
  op testMETARULES : -> MetaruleList .
  eq testMETARULES =
    metarule((p,a,b), (q,a,b)) ;
    metarule((p,a,b), (q,a,c), (r,c,b)) .

endfm