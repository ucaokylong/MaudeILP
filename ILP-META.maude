fmod ILP-META is
  protecting META-LEVEL .

  var M : Qid .
  var MM : Module .

  op ilpModule : Qid -> Module .
  eq ilpModule(M) = upModule(M, false) .

  op ilpSorts : Qid -> SortSet .
  eq ilpSorts(M) = getSorts(ilpModule(M)) .

  op ilpOps : Qid -> OpDeclSet .
  eq ilpOps(M) = getOps(ilpModule(M)) .

  op ilpEqs : Qid -> EquationSet .
  eq ilpEqs(M) = getEqs(ilpModule(M)) .
endfm
