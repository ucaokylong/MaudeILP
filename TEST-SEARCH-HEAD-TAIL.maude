load ILP-SEARCH.maude
load head-tail-case.maude

fmod TEST-SEARCH-HEAD-TAIL is
  protecting ILP-SEARCH .
  protecting HEAD-TAIL-CASE .
  protecting META-LEVEL .

  op M-PROB : -> [Module] .
  eq M-PROB = upModule('HEAD-TAIL-CASE, false) .
  
  op POS-Data : -> TermList . eq POS-Data = flattenList(getEqRhs(M-PROB, 'POS)) .
  op NEG-Data : -> TermList . eq NEG-Data = flattenList(getEqRhs(M-PROB, 'NEG)) .
  op BK-Data : -> TermList . eq BK-Data = flattenList(getEqRhs(M-PROB, 'BK)) .

  --- Lấy danh sách Metarules động từ file người dùng
  op MR-Data : -> TermList . 
  eq MR-Data = extractMetarules(getEqRhs(M-PROB, 'METARULES)) .

  --- Chạy thuật toán Metagol (Kỳ vọng máy bế tắc và bật Predicate Invention)
  op Induced-Program : -> ILPClauseSet .
  eq Induced-Program = learn(POS-Data, NEG-Data, BK-Data, emptyClauseSet, MR-Data) .

endfm

set trace off .

--- Chạy kiểm thử Predicate Invention
reduce in TEST-SEARCH-HEAD-TAIL : Induced-Program .